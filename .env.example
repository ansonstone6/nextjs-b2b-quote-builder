# Supabase Postgres — Prisma CLI loads `.env` then `.env.local` (see `prisma.config.ts`).
#
# DIRECT `db.<ref>.supabase.co:5432` often uses IPv6 only. If you see P1001 / "Can't reach database
# server" from a home/office network, use the pooled URI from the dashboard instead:
# Project -> Connect -> "Connection pooling" / Supavisor -> Session mode (IPv4-friendly).
# Example shape (region + project ref come from your dashboard):
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
#
# Direct (OK when your network can reach IPv6, or you use Supabase IPv4 add-on):
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Supabase project URL (Settings -> Data API, or API Keys page)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# New API keys (Settings -> API Keys -> "Publishable and secret API keys")
# Publishable: only if you call createSupabaseBrowserClient / createSupabaseServerClient (Auth, Realtime, Storage from the client). This app uses Prisma for data, so you can omit both Supabase keys until you wire those helpers.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Secret: only if you use createSupabaseAdminClient (e.g. server-side Storage bypassing RLS). Not used by the quote builder today.
# SUPABASE_SECRET_KEY="sb_secret_..."

# Legacy JWT keys (same page -> "Legacy anon, service_role") - still accepted as fallback
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Optional: PDF header text
# QUOTING_BRAND_NAME="Your company"

# QuickBooks Online (Intuit Developer -> app -> Keys & OAuth)
# Redirect URI must match exactly, e.g. http://localhost:3000/api/quickbooks/auth/callback
QBO_CLIENT_ID="your_intuit_client_id"
QBO_CLIENT_SECRET="your_intuit_client_secret"
QBO_REDIRECT_URI="http://localhost:3000/api/quickbooks/auth/callback"
QBO_ENVIRONMENT="sandbox"
# 32+ char secret for AES-256 token encryption at rest
TOKEN_ENCRYPTION_KEY="generate_a_long_random_string_here"

# AI 
OPENAI_API_KEY="sk-..."
